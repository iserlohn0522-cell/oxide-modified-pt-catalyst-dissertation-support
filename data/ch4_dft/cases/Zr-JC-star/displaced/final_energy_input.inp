&GLOBAL
  PROJECT_NAME public_Zr-JC-star_displaced
  RUN_TYPE ENERGY
  PRINT_LEVEL MEDIUM
&END GLOBAL




&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    CHARGE 0
    LSD
    MULTIPLICITY 1
    &MGRID
      CUTOFF 600
      REL_CUTOFF 50
      NGRIDS 5
    &END MGRID
    &QS
      METHOD GPW
      EPS_DEFAULT 1.0E-10
    &END QS
    &SCF
      MAX_SCF 1200
      EPS_SCF 1.0E-4
      SCF_GUESS ATOMIC
      ADDED_MOS 120
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.03
        NBROYDEN 8
      &END MIXING
      &SMEAR ON
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 300.0
      &END SMEAR
      &PRINT
        &RESTART
          BACKUP_COPIES 1
        &END RESTART
      &END PRINT
    &END SCF
    &PRINT
      &HIRSHFELD ON
        SELF_CONSISTENT T
        FILENAME ./hirshfeld
      &END HIRSHFELD
      &PDOS
        NLUMO 40
        FILENAME ./pdos
        LOG_PRINT_KEY T
      &LDOS
        COMPONENTS
        LIST 99 100 101 102 103 104
      &END LDOS
      &LDOS
        COMPONENTS
        LIST 93 94
      &END LDOS
      &LDOS
        COMPONENTS
        LIST 92 95 96 97 98
      &END LDOS
      &END PDOS
    &END PRINT
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3(BJ)
          REFERENCE_FUNCTIONAL PBE
          PARAMETER_FILE_NAME dftd3.dat
          CALCULATE_C9_TERM .FALSE.
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC
    &POISSON
      PERIODIC NONE
      PSOLVER MT
    &END POISSON
  &END DFT
  &SUBSYS
    &CELL
      ABC [angstrom] 30.0 30.0 40.0
      PERIODIC NONE
    &END CELL
    &TOPOLOGY
      COORD_FILE_NAME model.xyz
      COORD_FILE_FORMAT XYZ
    &END TOPOLOGY
    &KIND C
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q4
    &END KIND
    &KIND O
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND Pt
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q18
    &END KIND
    &KIND Zr
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q12
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
