&GLOBAL
  PROJECT public_Nb-JC_displaced
  RUN_TYPE ENERGY
  PRINT_LEVEL MEDIUM
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    CHARGE 0
    LSD
    MULTIPLICITY 1
    &MGRID
      CUTOFF 400
      REL_CUTOFF 50
      NGRIDS 4
    &END MGRID
    &QS
      METHOD GPW
      EPS_DEFAULT 1.0E-10
    &END QS
    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 1.0E-6
      MAX_SCF 800
      ADDED_MOS 120
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.05
        NBROYDEN 8
      &END MIXING
      &SMEAR ON
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 300
      &END SMEAR
      &OUTER_SCF
        EPS_SCF 1.0E-6
        MAX_SCF 16
      &END OUTER_SCF
      &PRINT
        &RESTART
          BACKUP_COPIES 1
        &END RESTART
      &END PRINT
    &END SCF
    &PRINT
      &HIRSHFELD ON
        SELF_CONSISTENT T
        FILENAME ./hirshfeld
      &END HIRSHFELD
      &PDOS
        NLUMO 20
        FILENAME ./pdos
        LOG_PRINT_KEY T
        &LDOS
          COMPONENTS
          LIST 100 101 102 103 104 105
        &END LDOS
      &END PDOS
    &END PRINT
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3(BJ)
          REFERENCE_FUNCTIONAL PBE
          PARAMETER_FILE_NAME dftd3.dat
          CALCULATE_C9_TERM .FALSE.
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      A 17.216585 0.000000 0.000000
      B 8.608293 14.910000 0.000000
      C 0.000000 0.000000 20.000000
      PERIODIC XYZ
    &END CELL
    &TOPOLOGY
      COORD_FILE_NAME model.xyz
      COORD_FILE_FORMAT XYZ
    &END TOPOLOGY
    &KIND C
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q4
    &END KIND
    &KIND Nb
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q13
    &END KIND
    &KIND O
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND Pt
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q18
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
